@prefix : <https://edugate.cs.wright.edu/lod/ontology/currKG/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource/currKG/> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology/currKG/> .
@base <https://edugate.cs.wright.edu/lod/ontology/currKG/> .

<https://edugate.cs.wright.edu/lod/ontology> rdf:type owl:Ontology .

#################################################################
#    Annotation properties
#################################################################

###  http://ontologydesignpatterns.org/opla-sd#entityPosition
<http://ontologydesignpatterns.org/opla-sd#entityPosition> rdf:type owl:AnnotationProperty .


###  http://ontologydesignpatterns.org/opla-sd#entityPositionX
<http://ontologydesignpatterns.org/opla-sd#entityPositionX> rdf:type owl:AnnotationProperty .


###  http://ontologydesignpatterns.org/opla-sd#entityPositionY
<http://ontologydesignpatterns.org/opla-sd#entityPositionY> rdf:type owl:AnnotationProperty .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/isNativeTo
edu-ont:isNativeTo rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  https://edugate.cs.wright.edu/lod/ontology/currKG/assumesAuthorship
edu-ont:assumesAuthorship rdf:type owl:ObjectProperty ;
                          rdfs:domain edu-ont:Person ;
                          rdfs:range edu-ont:Author ;
                          rdfs:comment "Represents the relation of a person to an author role they assume."@en ;
                          rdfs:label "assumes authorship"@en .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/assumesPersona
edu-ont:assumesPersona rdf:type owl:ObjectProperty ;
                       rdfs:domain edu-ont:Person ;
                       rdfs:range edu-ont:Persona ;
                       rdfs:comment "Represents the relation of a person to a persona role they assume."@en ;
                       rdfs:label "assumes persona"@en .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/belongTo
edu-ont:belongTo rdf:type owl:ObjectProperty ;
                 rdfs:domain edu-ont:Module ;
                 rdfs:range edu-ont:Category ;
                 rdfs:comment "Represents the relation of a module to the category it belongs to."@en ;
                 rdfs:label "belongs to"@en .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/broaderThan
edu-ont:broaderThan rdf:type owl:ObjectProperty ;
                    rdfs:domain edu-ont:Topic ;
                    rdfs:range edu-ont:Topic ;
                    rdfs:comment "Represents the relation of a topic to a broader (more general) topic."@en ;
                    rdfs:label "broader than"@en .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/coversTopic
edu-ont:coversTopic rdf:type owl:ObjectProperty ;
                    rdfs:domain [ rdf:type owl:Class ;
                                  owl:unionOf ( edu-ont:Media
                                                edu-ont:Module
                                              )
                                ] ;
                    rdfs:range edu-ont:Topic ;
                    rdfs:comment "Represents the relation of a module or media resource to a topic it covers."@en ;
                    rdfs:label "covers topic"@en .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/determines
edu-ont:determines rdf:type owl:ObjectProperty ;
                   rdfs:domain edu-ont:Persona ;
                   rdfs:range edu-ont:LearningPath ;
                   rdfs:comment "Represents the relation of a persona to the learning path it determines."@en ;
                   rdfs:label "determines"@en .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/hasAuthor
edu-ont:hasAuthor rdf:type owl:ObjectProperty ;
                  rdfs:domain edu-ont:Media ;
                  rdfs:range edu-ont:Author ;
                  rdfs:comment "Represents the relation of a media resource to its author."@en ;
                  rdfs:label "has author"@en .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/hasLanguage
edu-ont:hasLanguage rdf:type owl:ObjectProperty ;
                    rdfs:domain edu-ont:Media ;
                    rdfs:range edu-ont:Language ;
                    rdfs:comment "Represents the relation of a media resource to the language it is in."@en ;
                    rdfs:label "has language"@en .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/hasLearningStep
edu-ont:hasLearningStep rdf:type owl:ObjectProperty ;
                        rdfs:domain edu-ont:LearningPath ;
                        rdfs:range edu-ont:LearningStep ;
                        rdfs:comment "Represents the relation of a learning path to a learning step that it contains."@en ;
                        rdfs:label "has learning step"@en .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/hasLevel
edu-ont:hasLevel rdf:type owl:ObjectProperty ;
                 rdfs:domain edu-ont:Module ;
                 rdfs:range edu-ont:Level ;
                 rdfs:comment "Represents the relation of a module to its difficulty level."@en ;
                 rdfs:label "has level"@en .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/hasModule
edu-ont:hasModule rdf:type owl:ObjectProperty ;
                  rdfs:domain edu-ont:Curriculum ;
                  rdfs:range edu-ont:Module ;
                  rdfs:comment "Represents the relation of referring a curriculum to a module that is part of that curriculum."@en ;
                  rdfs:label "has module"@en .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/hasNextLearningStep
edu-ont:hasNextLearningStep rdf:type owl:ObjectProperty ;
                            rdfs:domain edu-ont:LearningStep ;
                            rdfs:range edu-ont:LearningStep ;
                            rdfs:comment "Represents the relation of a learning step to the next learning step in the sequence."@en ;
                            rdfs:label "has next learning step"@en .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/hasPreviousLearningStep
edu-ont:hasPreviousLearningStep rdf:type owl:ObjectProperty ;
                                rdfs:domain edu-ont:LearningStep ;
                                rdfs:range edu-ont:LearningStep ;
                                rdfs:comment "Represents the relation of a learning step to the previous learning step in the sequence."@en ;
                                rdfs:label "has previous learning step"@en .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/hasProfession
edu-ont:hasProfession rdf:type owl:ObjectProperty ;
                      rdfs:domain edu-ont:Persona ;
                      rdfs:range edu-ont:Profession ;
                      rdfs:comment "Represents the relation of a persona to its profession."@en ;
                      rdfs:label "has profession"@en .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/hasRecomended
edu-ont:hasRecomended rdf:type owl:ObjectProperty ;
                      rdfs:domain edu-ont:Media ;
                      rdfs:range edu-ont:Audience ;
                      rdfs:comment "Represents the relation of a media resource to an intended audience it is recommended for."@en ;
                      rdfs:label "has recommended audience"@en .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/hasSubEvent
edu-ont:hasSubEvent rdf:type owl:ObjectProperty ;
                    rdfs:domain edu-ont:Event ;
                    rdfs:range edu-ont:Event ;
                    rdfs:comment "Represents the relation of an event to a sub-event that is part of it."@en ;
                    rdfs:label "has sub-event"@en .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/hasType
edu-ont:hasType rdf:type owl:ObjectProperty ;
                rdfs:domain edu-ont:Persona ;
                rdfs:range edu-ont:PersonaType ;
                rdfs:comment "Represents the relation of a persona to its persona type."@en ;
                rdfs:label "has type"@en .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/narrowerThan
edu-ont:narrowerThan rdf:type owl:ObjectProperty ;
                     rdfs:domain edu-ont:Topic ;
                     rdfs:range edu-ont:Topic ;
                     rdfs:comment "Represents the relation of a topic to a narrower (more specific) topic."@en ;
                     rdfs:label "narrower than"@en .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/provides
edu-ont:provides rdf:type owl:ObjectProperty ;
                 rdfs:domain edu-ont:Event ;
                 rdfs:range edu-ont:Media ;
                 rdfs:comment "Represents the relation of an event to media resources it provides."@en ;
                 rdfs:label "provides"@en .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/references
edu-ont:references rdf:type owl:ObjectProperty ;
                   rdfs:domain edu-ont:Module ;
                   rdfs:range edu-ont:Media ;
                   rdfs:comment "Represents the relation of a module (or other entity) to media resources that it references."@en ;
                   rdfs:label "references"@en .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/refersTo
edu-ont:refersTo rdf:type owl:ObjectProperty ;
                 rdfs:domain edu-ont:LearningStep ;
                 rdfs:range edu-ont:Module ;
                 rdfs:comment "Represents the relation of a learning step to the module it refers to."@en ;
                 rdfs:label "refers to"@en .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/scopedBy
edu-ont:scopedBy rdf:type owl:ObjectProperty ;
                 rdfs:domain edu-ont:LearningPath ;
                 rdfs:range edu-ont:Curriculum ;
                 rdfs:comment "Represents the relation of a learning path to the curriculum that scopes it."@en ;
                 rdfs:label "scoped by"@en .


#################################################################
#    Data properties
#################################################################

###  https://edugate.cs.wright.edu/lod/ontology/currKG/asString
edu-ont:asString rdf:type owl:DatatypeProperty ;
                 rdfs:domain [ rdf:type owl:Class ;
                               owl:unionOf ( edu-ont:Event
                                             edu-ont:LearningPath
                                             edu-ont:LearningStep
                                             edu-ont:Persona
                                             edu-ont:PersonaType
                                             edu-ont:Profession
                                             edu-ont:Topic
                                           )
                             ] ;
                 rdfs:range xsd:string ;
                 rdfs:comment "Provides a string lexicalization or label for a resource."@en ;
                 rdfs:label "as string"@en .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/hasMediaSourceLink
edu-ont:hasMediaSourceLink rdf:type owl:DatatypeProperty ;
                           rdfs:domain edu-ont:Media ;
                           rdfs:range xsd:string ;
                           rdfs:comment "Provides the source link or URL string for a media resource."@en ;
                           rdfs:label "has media source link"@en .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/hasName
edu-ont:hasName rdf:type owl:DatatypeProperty ;
                rdfs:domain edu-ont:Author ;
                rdfs:range xsd:string ;
                rdfs:comment "Provides a human-readable name string for a resource."@en ;
                rdfs:label "has name"@en .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/hasTitle
edu-ont:hasTitle rdf:type owl:DatatypeProperty ;
                 rdfs:domain [ rdf:type owl:Class ;
                               owl:unionOf ( edu-ont:Curriculum
                                             edu-ont:Media
                                             edu-ont:Module
                                           )
                             ] ;
                 rdfs:range xsd:string ;
                 rdfs:comment "Provides a title string for a resource."@en ;
                 rdfs:label "has title"@en .


#################################################################
#    Classes
#################################################################

###  https://edugate.cs.wright.edu/lod/ontology/currKG/Article
edu-ont:Article rdf:type owl:Class ;
                rdfs:subClassOf edu-ont:Media ;
                <http://ontologydesignpatterns.org/opla-sd#entityPosition> [ <http://ontologydesignpatterns.org/opla-sd#entityPositionX> "46.144836640895754"^^xsd:double ;
                                                                             <http://ontologydesignpatterns.org/opla-sd#entityPositionY> "247.41338370020338"^^xsd:double ;
                                                                             rdfs:comment "This is an entity positioning annotation generated by CoModIDE (https://comodide.com/). Removing this annotation will break rendering the CoModIDE schema diagram view."@en
                                                                           ] ;
                rdfs:comment "Represents an Article is a written media resource, typed as a sub-class."@en ;
                rdfs:label "Article"@en .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/Audience
edu-ont:Audience rdf:type owl:Class ;
                 rdfs:comment "Represents audience as a controlled vocabulary that is used to indicate intended audience for a media resource."@en ;
                 rdfs:label "Audience"@en .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/Author
edu-ont:Author rdf:type owl:Class ;
               rdfs:subClassOf [ rdf:type owl:Restriction ;
                                 owl:onProperty edu-ont:hasName ;
                                 owl:someValuesFrom xsd:string
                               ] ;
               <http://ontologydesignpatterns.org/opla-sd#entityPosition> [ <http://ontologydesignpatterns.org/opla-sd#entityPositionX> "212.2044628151925"^^xsd:double ;
                                                                            <http://ontologydesignpatterns.org/opla-sd#entityPositionY> "117.51617792023181"^^xsd:double ;
                                                                            rdfs:comment "This is an entity positioning annotation generated by CoModIDE (https://comodide.com/). Removing this annotation will break rendering the CoModIDE schema diagram view."@en
                                                                          ] ;
               rdfs:comment "Represents an author that is a person who creates or is credited for media resources."@en ;
               rdfs:label "Author"@en ;
               edu-ont:isNativeTo <https://archive.org/services/purl/domain/modular_ontology_design_library/agentrole> ,
                                  <https://archive.org/services/purl/domain/modular_ontology_design_library/role-dependent-name> .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/Category
edu-ont:Category rdf:type owl:Class ;
                 rdfs:subClassOf [ rdf:type owl:Restriction ;
                                   owl:onProperty [ owl:inverseOf edu-ont:belongTo
                                                  ] ;
                                   owl:someValuesFrom edu-ont:Module
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty edu-ont:hasTitle ;
                                   owl:someValuesFrom xsd:string
                                 ] ;
                 <http://ontologydesignpatterns.org/opla-sd#entityPosition> [ <http://ontologydesignpatterns.org/opla-sd#entityPositionX> "66.0082422042512"^^xsd:double ;
                                                                              <http://ontologydesignpatterns.org/opla-sd#entityPositionY> "163.11457706181378"^^xsd:double ;
                                                                              rdfs:comment "This is an entity positioning annotation generated by CoModIDE (https://comodide.com/). Removing this annotation will break rendering the CoModIDE schema diagram view."@en
                                                                            ] ;
                 rdfs:comment "Represents a category is a high-level grouping used to organize modules (e.g., foundations, survey, methodology, standards)."@en ;
                 rdfs:label "Category"@en ;
                 edu-ont:isNativeTo <https://archive.org/services/purl/domain/modular_ontology_design_library/PartWhole> .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/Curriculum
edu-ont:Curriculum rdf:type owl:Class ;
                   rdfs:subClassOf [ rdf:type owl:Restriction ;
                                     owl:onProperty edu-ont:hasModule ;
                                     owl:someValuesFrom edu-ont:Module
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty edu-ont:hasTitle ;
                                     owl:someValuesFrom xsd:string
                                   ] ;
                   <http://ontologydesignpatterns.org/opla-sd#entityPosition> [ <http://ontologydesignpatterns.org/opla-sd#entityPositionX> "84.22046954254326"^^xsd:double ;
                                                                                <http://ontologydesignpatterns.org/opla-sd#entityPositionY> "61.85682749202153"^^xsd:double ;
                                                                                rdfs:comment "This is an entity positioning annotation generated by CoModIDE (https://comodide.com/). Removing this annotation will break rendering the CoModIDE schema diagram view."@en
                                                                              ] ;
                   rdfs:comment "Represents a Curriculum as a curated course of study that groups modules into a coherent educational offering."@en ;
                   rdfs:label "Curriculum"@en ;
                   edu-ont:isNativeTo <https://archive.org/services/purl/domain/modular_ontology_design_library/namestub> .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/Event
edu-ont:Event rdf:type owl:Class ;
              rdfs:subClassOf [ rdf:type owl:Restriction ;
                                owl:onProperty edu-ont:provides ;
                                owl:someValuesFrom edu-ont:Media
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty edu-ont:hasSubEvent ;
                                owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
                                owl:onClass edu-ont:Event
                              ] ;
              <http://ontologydesignpatterns.org/opla-sd#entityPosition> [ <http://ontologydesignpatterns.org/opla-sd#entityPositionX> "222.95598092682775"^^xsd:double ;
                                                                           <http://ontologydesignpatterns.org/opla-sd#entityPositionY> "20.29786947182403"^^xsd:double ;
                                                                           rdfs:comment "This is an entity positioning annotation generated by CoModIDE (https://comodide.com/). Removing this annotation will break rendering the CoModIDE schema diagram view."@en
                                                                         ] ;
              rdfs:comment "Represents an event as a structured learning activity (e.g., workshop, tutorial, presentation) that can provide media and have sub-events."@en ;
              rdfs:label "Event"@en ;
              edu-ont:isNativeTo <https://archive.org/services/purl/domain/modular_ontology_design_library/event> .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/FirstLearningStep
edu-ont:FirstLearningStep rdf:type owl:Class ;
                          rdfs:subClassOf edu-ont:LearningStep ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty edu-ont:refersTo ;
                                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                            owl:onClass edu-ont:Module
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty edu-ont:hasPreviousLearningStep ;
                                            owl:maxQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
                                            owl:onClass edu-ont:LearningStep
                                          ] ;
                          <http://ontologydesignpatterns.org/opla-sd#entityPosition> [ <http://ontologydesignpatterns.org/opla-sd#entityPositionX> "121.96218406852572"^^xsd:double ;
                                                                                       <http://ontologydesignpatterns.org/opla-sd#entityPositionY> "261.79752540381384"^^xsd:double ;
                                                                                       rdfs:comment "This is an entity positioning annotation generated by CoModIDE (https://comodide.com/). Removing this annotation will break rendering the CoModIDE schema diagram view."@en
                                                                                     ] ;
                          rdfs:comment "Represents a First Learning Step that marks the starting step of a learning path."@en ;
                          rdfs:label "First Learning Step"@en .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/Foundations
edu-ont:Foundations rdf:type owl:Class ;
                    rdfs:subClassOf edu-ont:Category ;
                    <http://ontologydesignpatterns.org/opla-sd#entityPosition> [ <http://ontologydesignpatterns.org/opla-sd#entityPositionX> "119.63769059552737"^^xsd:double ;
                                                                                 <http://ontologydesignpatterns.org/opla-sd#entityPositionY> "259.7961852328274"^^xsd:double ;
                                                                                 rdfs:comment "This is an entity positioning annotation generated by CoModIDE (https://comodide.com/). Removing this annotation will break rendering the CoModIDE schema diagram view."@en
                                                                               ] ;
                    rdfs:comment "Represents Foundations as a category subclass for modules covering fundamental concepts and principles."@en ;
                    rdfs:label "Foundations"@en .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/Language
edu-ont:Language rdf:type owl:Class ;
                 <http://ontologydesignpatterns.org/opla-sd#entityPosition> [ <http://ontologydesignpatterns.org/opla-sd#entityPositionX> "58.90193677825256"^^xsd:double ;
                                                                              <http://ontologydesignpatterns.org/opla-sd#entityPositionY> "164.73174749711126"^^xsd:double ;
                                                                              rdfs:comment "This is an entity positioning annotation generated by CoModIDE (https://comodide.com/). Removing this annotation will break rendering the CoModIDE schema diagram view."@en
                                                                            ] ;
                 rdfs:comment "Represents a Language indicating the language of a media resource."@en ;
                 rdfs:label "Language"@en .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/LastLearningStep
edu-ont:LastLearningStep rdf:type owl:Class ;
                         rdfs:subClassOf edu-ont:LearningStep ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty edu-ont:refersTo ;
                                           owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                           owl:onClass edu-ont:Module
                                         ] ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty edu-ont:hasNextLearningStep ;
                                           owl:maxQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
                                           owl:onClass edu-ont:LearningStep
                                         ] ;
                         <http://ontologydesignpatterns.org/opla-sd#entityPosition> [ <http://ontologydesignpatterns.org/opla-sd#entityPositionX> "103.47116996503698"^^xsd:double ;
                                                                                      <http://ontologydesignpatterns.org/opla-sd#entityPositionY> "69.51171184630267"^^xsd:double ;
                                                                                      rdfs:comment "This is an entity positioning annotation generated by CoModIDE (https://comodide.com/). Removing this annotation will break rendering the CoModIDE schema diagram view."@en
                                                                                    ] ;
                         rdfs:comment "Represents a Last Learning Step that marks the ending step of a learning path."@en ;
                         rdfs:label "Last Learning Step"@en .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/LearningPath
edu-ont:LearningPath rdf:type owl:Class ;
                     rdfs:subClassOf [ rdf:type owl:Restriction ;
                                       owl:onProperty edu-ont:hasLearningStep ;
                                       owl:someValuesFrom edu-ont:LearningStep
                                     ] ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty edu-ont:scopedBy ;
                                       owl:someValuesFrom edu-ont:Curriculum
                                     ] ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty [ owl:inverseOf edu-ont:determines
                                                      ] ;
                                       owl:someValuesFrom edu-ont:Persona
                                     ] ;
                     <http://ontologydesignpatterns.org/opla-sd#entityPosition> [ <http://ontologydesignpatterns.org/opla-sd#entityPositionX> "299.49419969429334"^^xsd:double ;
                                                                                  <http://ontologydesignpatterns.org/opla-sd#entityPositionY> "165.28410508436227"^^xsd:double ;
                                                                                  rdfs:comment "This is an entity positioning annotation generated by CoModIDE (https://comodide.com/). Removing this annotation will break rendering the CoModIDE schema diagram view."@en
                                                                                ] ;
                     rdfs:comment "Represents a Learning Path as an ordered sequence of learning steps tailored to a persona and scoped by a curriculum."@en ;
                     rdfs:label "Learning Path"@en .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/LearningStep
edu-ont:LearningStep rdf:type owl:Class ;
                     rdfs:subClassOf [ rdf:type owl:Restriction ;
                                       owl:onProperty edu-ont:hasNextLearningStep ;
                                       owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
                                       owl:onClass edu-ont:LearningStep
                                     ] ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty edu-ont:hasPreviousLearningStep ;
                                       owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
                                       owl:onClass edu-ont:LearningStep
                                     ] ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty edu-ont:refersTo ;
                                       owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                       owl:onClass edu-ont:Module
                                     ] ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty edu-ont:hasNextLearningStep ;
                                       owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                       owl:onClass edu-ont:LearningStep
                                     ] ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty edu-ont:hasPreviousLearningStep ;
                                       owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                       owl:onClass edu-ont:LearningStep
                                     ] ;
                     <http://ontologydesignpatterns.org/opla-sd#entityPosition> [ <http://ontologydesignpatterns.org/opla-sd#entityPositionX> "195.52378966483667"^^xsd:double ;
                                                                                  <http://ontologydesignpatterns.org/opla-sd#entityPositionY> "113.96282514832542"^^xsd:double ;
                                                                                  rdfs:comment "This is an entity positioning annotation generated by CoModIDE (https://comodide.com/). Removing this annotation will break rendering the CoModIDE schema diagram view."@en
                                                                                ] ;
                     rdfs:comment "Represents a Learning Step as an ordered step within a Learning Path that refers to exactly one module."@en ;
                     rdfs:label "Learning Step"@en ;
                     edu-ont:isNativeTo <https://archive.org/services/purl/domain/modular_ontology_design_library/recurrentevent> .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/Level
edu-ont:Level rdf:type owl:Class ;
              <http://ontologydesignpatterns.org/opla-sd#entityPosition> [ <http://ontologydesignpatterns.org/opla-sd#entityPositionX> "83.5387145526865"^^xsd:double ;
                                                                           <http://ontologydesignpatterns.org/opla-sd#entityPositionY> "256.9006692958464"^^xsd:double ;
                                                                           rdfs:comment "This is an entity positioning annotation generated by CoModIDE (https://comodide.com/). Removing this annotation will break rendering the CoModIDE schema diagram view."@en
                                                                         ] ;
              rdfs:comment "Represents Level as a controlled vocabulary indicating the difficulty of a module."@en ;
              rdfs:label "Level"@en ;
              edu-ont:isNativeTo <https://archive.org/services/purl/domain/modular_ontology_design_library/explicittyping> .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/Media
edu-ont:Media rdf:type owl:Class ;
              rdfs:subClassOf [ rdf:type owl:Restriction ;
                                owl:onProperty edu-ont:coversTopic ;
                                owl:someValuesFrom edu-ont:Topic
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty edu-ont:hasAuthor ;
                                owl:someValuesFrom edu-ont:Author
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty edu-ont:hasLanguage ;
                                owl:someValuesFrom edu-ont:Language
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty edu-ont:hasRecomended ;
                                owl:someValuesFrom edu-ont:Audience
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty edu-ont:hasMediaSourceLink ;
                                owl:someValuesFrom xsd:string
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty edu-ont:hasTitle ;
                                owl:someValuesFrom xsd:string
                              ] ;
              <http://ontologydesignpatterns.org/opla-sd#entityPosition> [ <http://ontologydesignpatterns.org/opla-sd#entityPositionX> "56.22964736735543"^^xsd:double ;
                                                                           <http://ontologydesignpatterns.org/opla-sd#entityPositionY> "192.4576250484204"^^xsd:double ;
                                                                           rdfs:comment "This is an entity positioning annotation generated by CoModIDE (https://comodide.com/). Removing this annotation will break rendering the CoModIDE schema diagram view."@en
                                                                         ] ;
              rdfs:comment "Represents a Media that is a learning resource (e.g., article, video, podcast, transcript) and can be referenced by modules or provided by events."@en ;
              rdfs:label "Media"@en ;
              edu-ont:isNativeTo <https://archive.org/services/purl/domain/modular_ontology_design_library/reporting-event> .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/Module
edu-ont:Module rdf:type owl:Class ;
               rdfs:subClassOf [ rdf:type owl:Restriction ;
                                 owl:onProperty edu-ont:belongTo ;
                                 owl:someValuesFrom edu-ont:Category
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty edu-ont:coversTopic ;
                                 owl:someValuesFrom edu-ont:Topic
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty edu-ont:hasLevel ;
                                 owl:someValuesFrom edu-ont:Level
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty edu-ont:references ;
                                 owl:someValuesFrom edu-ont:Media
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty edu-ont:hasTitle ;
                                 owl:someValuesFrom xsd:string
                               ] ;
               <http://ontologydesignpatterns.org/opla-sd#entityPosition> [ <http://ontologydesignpatterns.org/opla-sd#entityPositionX> "11.961109252390985"^^xsd:double ;
                                                                            <http://ontologydesignpatterns.org/opla-sd#entityPositionY> "294.8983475284603"^^xsd:double ;
                                                                            rdfs:comment "This is an entity positioning annotation generated by CoModIDE (https://comodide.com/). Removing this annotation will break rendering the CoModIDE schema diagram view."@en
                                                                          ] ;
               rdfs:comment "Represents Module as a unit of learning content that covers one or more topics and references supporting media."@en ;
               rdfs:label "Module"@en ;
               edu-ont:isNativeTo <https://archive.org/services/purl/domain/modular_ontology_design_library/PartWhole> .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/Person
edu-ont:Person rdf:type owl:Class ;
               rdfs:subClassOf [ rdf:type owl:Restriction ;
                                 owl:onProperty edu-ont:assumesAuthorship ;
                                 owl:someValuesFrom edu-ont:Author
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty edu-ont:assumesPersona ;
                                 owl:someValuesFrom edu-ont:Persona
                               ] ;
               <http://ontologydesignpatterns.org/opla-sd#entityPosition> [ <http://ontologydesignpatterns.org/opla-sd#entityPositionX> "67.71024379246852"^^xsd:double ;
                                                                            <http://ontologydesignpatterns.org/opla-sd#entityPositionY> "93.39558214157489"^^xsd:double ;
                                                                            rdfs:comment "This is an entity positioning annotation generated by CoModIDE (https://comodide.com/). Removing this annotation will break rendering the CoModIDE schema diagram view."@en
                                                                          ] ;
               rdfs:comment "Represents Person is an Agent (from Agent Role pattern) who may assume roles such as persona or author."@en ;
               rdfs:label "Person"@en ;
               edu-ont:isNativeTo <https://archive.org/services/purl/domain/modular_ontology_design_library/role-dependent-name> .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/Persona
edu-ont:Persona rdf:type owl:Class ;
                rdfs:subClassOf [ rdf:type owl:Restriction ;
                                  owl:onProperty edu-ont:hasType ;
                                  owl:someValuesFrom edu-ont:PersonaType
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty [ owl:inverseOf edu-ont:assumesPersona
                                                 ] ;
                                  owl:someValuesFrom edu-ont:Person
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty edu-ont:determines ;
                                  owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                  owl:onClass edu-ont:LearningPath
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty edu-ont:hasProfession ;
                                  owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                  owl:onClass edu-ont:Profession
                                ] ;
                <http://ontologydesignpatterns.org/opla-sd#entityPosition> [ <http://ontologydesignpatterns.org/opla-sd#entityPositionX> "234.79032302270195"^^xsd:double ;
                                                                             <http://ontologydesignpatterns.org/opla-sd#entityPositionY> "105.44392300174702"^^xsd:double ;
                                                                             rdfs:comment "This is an entity positioning annotation generated by CoModIDE (https://comodide.com/). Removing this annotation will break rendering the CoModIDE schema diagram view."@en
                                                                           ] ;
                rdfs:comment "Represents Persona as an audience profile (role/background) used to tailor a learning path.e"@en ;
                rdfs:label "Persona"@en ;
                edu-ont:isNativeTo <https://archive.org/services/purl/domain/modular_ontology_design_library/role-dependent-name> .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/PersonaType
edu-ont:PersonaType rdf:type owl:Class ;
                    rdfs:comment "Represents Persona Type as a controlled vocabulary used to classify personas (e.g., developer, executive)."@en ;
                    rdfs:label "Persona Type"@en ;
                    edu-ont:isNativeTo <https://archive.org/services/purl/domain/modular_ontology_design_library/explicittyping> .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/Podcast
edu-ont:Podcast rdf:type owl:Class ;
                rdfs:subClassOf edu-ont:Media ;
                <http://ontologydesignpatterns.org/opla-sd#entityPosition> [ <http://ontologydesignpatterns.org/opla-sd#entityPositionX> "88.35855842870635"^^xsd:double ;
                                                                             <http://ontologydesignpatterns.org/opla-sd#entityPositionY> "85.13207349708281"^^xsd:double ;
                                                                             rdfs:comment "This is an entity positioning annotation generated by CoModIDE (https://comodide.com/). Removing this annotation will break rendering the CoModIDE schema diagram view."@en
                                                                           ] ;
                rdfs:comment "Represents a Podcast as an audio media resource, typed as a sub-class."@en ;
                rdfs:label "Podcast"@en .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/Presentation
edu-ont:Presentation rdf:type owl:Class ;
                     rdfs:subClassOf edu-ont:Event ;
                     <http://ontologydesignpatterns.org/opla-sd#entityPosition> [ <http://ontologydesignpatterns.org/opla-sd#entityPositionX> "4.872849163765131"^^xsd:double ;
                                                                                  <http://ontologydesignpatterns.org/opla-sd#entityPositionY> "249.09322448025713"^^xsd:double ;
                                                                                  rdfs:comment "This is an entity positioning annotation generated by CoModIDE (https://comodide.com/). Removing this annotation will break rendering the CoModIDE schema diagram view."@en
                                                                                ] ;
                     rdfs:comment "Represents a Presentationas an event type focused on delivering content to an audience, typed as a sub-class."@en ;
                     rdfs:label "Presentation"@en .


###  https://edugate.cs.wright.edu/lod/ontology/currKG/Profession
edu-ont:Profession rdf:type owl:Class ;
                   rdfs:subClassOf [ rdf:type owl:Restriction ;
                                     owl:onProperty edu-ont:asString ;
                                     owl:someValuesFrom xsd:string
                                   ] ;
