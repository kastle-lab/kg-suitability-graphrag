@prefix : <https://enslaved.org/ontology/> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix opla: <http://ontologydesignpatterns.org/opla#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix terms: <http://purl.org/dc/terms/> .
@prefix dcterms: <https://www.dublincore.org/specifications/dublin-core/dcmi-terms/> .
@prefix enslaved: <https://enslaved.org/ontology/> .
@base <https://enslaved.org/ontology/> .

<https://enslaved.org/ontology/> rdf:type owl:Ontology ;
                                  owl:versionIRI <https://enslaved.org/ontology/1.0.0> ;
                                  dc:title "The Enslaved Ontology" ;
                                  terms:creator "Alicia M. Sheill" ,
                                                "Catherine Foley" ,
                                                "Cogan Shimizu" ,
                                                "Dean Rehberger" ,
                                                "Duncan Tarr" ,
                                                "Ethan Watrall" ,
                                                "Jeff Mixter" ,
                                                "Pascal Hitzler" ,
                                                "Quinn Hirt" ,
                                                "Ryan Carty" ,
                                                "Seila Gonzalez Estrecha" ,
                                                "Walter Hawthorne" ;
                                  terms:license "https://creativecommons.org/licenses/by/4.0/"^^xsd:anyURI ,
                                                "CC by 4.0" ;
                                  terms:rights "CC by 4.0" .

#################################################################
#    Annotation properties
#################################################################

###  http://ontologydesignpatterns.org/opla#isNativeTo
opla:isNativeTo rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/title
dc:title rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
terms:creator rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
terms:license rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/rights
terms:rights rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  https://enslaved.org/ontology/agentRecordSelfProperty
enslaved:agentRecordSelfProperty rdf:type owl:ObjectProperty ;
                                 rdfs:domain enslaved:AgentRecord ;
                                 rdfs:range enslaved:AgentRecord ;
                                 opla:isNativeTo "https://enslaved.org/ontology/Event"^^rdfs:Literal .


###  https://enslaved.org/ontology/asPlaceCV
enslaved:asPlaceCV rdf:type owl:ObjectProperty ;
                   rdfs:domain enslaved:Place ;
                   rdfs:range enslaved:PlaceCV ;
                   opla:isNativeTo "https://enslaved.org/ontology/Place"^^rdfs:Literal .


###  https://enslaved.org/ontology/atPlace
enslaved:atPlace rdf:type owl:ObjectProperty ;
                 rdfs:domain enslaved:Event ;
                 rdfs:range enslaved:Place ;
                 opla:isNativeTo "https://enslaved.org/ontology/Event"^^rdfs:Literal .


###  https://enslaved.org/ontology/attributedTo
enslaved:attributedTo rdf:type owl:ObjectProperty ;
                      rdfs:domain enslaved:EntityWithProvenance ;
                      rdfs:range enslaved:Agent ;
                      opla:isNativeTo "https://enslaved.org/ontology/EntityWithProvenance"^^rdfs:Literal .


###  https://enslaved.org/ontology/eventSelfProperty
enslaved:eventSelfProperty rdf:type owl:ObjectProperty ;
                           rdfs:domain enslaved:Event ;
                           rdfs:range enslaved:Event ;
                           opla:isNativeTo "https://enslaved.org/ontology/Event"^^rdfs:Literal .


###  https://enslaved.org/ontology/fallsWithin
enslaved:fallsWithin rdf:type owl:ObjectProperty ;
                     rdfs:domain enslaved:TemporalExtent ;
                     rdfs:range enslaved:TimeSpan ;
                     opla:isNativeTo "https://enslaved.org/ontology/TemporalExtent"^^rdfs:Literal .


###  https://enslaved.org/ontology/generatedBy
enslaved:generatedBy rdf:type owl:ObjectProperty ;
                     rdfs:domain enslaved:EntityWithProvenance ;
                     rdfs:range enslaved:ProvenanceActivity ;
                     opla:isNativeTo "https://enslaved.org/ontology/EntityWithProvenance"^^rdfs:Literal .


###  https://enslaved.org/ontology/hasAgeRecord
enslaved:hasAgeRecord rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf enslaved:hasPersonRecord ;
                      rdfs:domain enslaved:Person ;
                      rdfs:range enslaved:AgeRecord .


###  https://enslaved.org/ontology/hasAgentRecord
enslaved:hasAgentRecord rdf:type owl:ObjectProperty ;
                        rdfs:domain enslaved:Agent ;
                        rdfs:range enslaved:AgentRecord ;
                        opla:isNativeTo "https://enslaved.org/ontology/Agent"^^rdfs:Literal .


###  https://enslaved.org/ontology/hasBroader
enslaved:hasBroader rdf:type owl:ObjectProperty ;
                    rdfs:domain [ rdf:type owl:Class ;
                                  owl:unionOf ( enslaved:Place
                                                enslaved:PlaceCV
                                              )
                                ] ;
                    rdfs:range enslaved:PlaceCV .


###  https://enslaved.org/ontology/hasCoordinates
enslaved:hasCoordinates rdf:type owl:ObjectProperty ;
                        rdfs:domain enslaved:Place ;
                        rdfs:range enslaved:Coordinates ;
                        opla:isNativeTo "https://enslaved.org/ontology/Place"^^rdfs:Literal .


###  https://enslaved.org/ontology/hasDescriptionText
enslaved:hasDescriptionText rdf:type owl:ObjectProperty ;
                            rdfs:domain [ rdf:type owl:Class ;
                                          owl:unionOf ( enslaved:Agent
                                                        enslaved:Event
                                                        enslaved:Place
                                                      )
                                        ] ;
                            rdfs:range enslaved:Description ;
                            opla:isNativeTo "https://enslaved.org/ontology/Agent"^^rdfs:Literal ,
                                            "https://enslaved.org/ontology/Event"^^rdfs:Literal ,
                                            "https://enslaved.org/ontology/Place"^^rdfs:Literal ,
                                            "https://enslaved.org/ontology/ResearchProject"^^rdfs:Literal .


###  https://enslaved.org/ontology/hasECVO
enslaved:hasECVO rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf owl:topObjectProperty ;
                 rdfs:domain enslaved:OriginRecord ;
                 rdfs:range enslaved:ECVO ;
                 opla:isNativeTo "https://enslaved.org/ontology/OriginRecord"^^rdfs:Literal .


###  https://enslaved.org/ontology/hasEventType
enslaved:hasEventType rdf:type owl:ObjectProperty ;
                      rdfs:domain enslaved:Event ;
                      rdfs:range enslaved:EventTypes ;
                      opla:isNativeTo "https://enslaved.org/ontology/Event"^^rdfs:Literal .


###  https://enslaved.org/ontology/hasExternalReference
enslaved:hasExternalReference rdf:type owl:ObjectProperty ;
                              rdfs:domain [ rdf:type owl:Class ;
                                            owl:unionOf ( enslaved:Agent
                                                          enslaved:Event
                                                        )
                                          ] ;
                              rdfs:range enslaved:ExternalReference ;
                              opla:isNativeTo "https://enslaved.org/ontology/Agent"^^rdfs:Literal ,
                                              "https://enslaved.org/ontology/Event"^^rdfs:Literal ,
                                              "https://enslaved.org/ontology/ResearchProject"^^rdfs:Literal .


###  https://enslaved.org/ontology/hasInterAgentRelationshipRecord
enslaved:hasInterAgentRelationshipRecord rdf:type owl:ObjectProperty ;
                                         rdfs:subPropertyOf enslaved:hasAgentRecord ;
                                         rdfs:domain enslaved:Agent ;
                                         rdfs:range enslaved:InterAgentRelationshipRecord .


###  https://enslaved.org/ontology/hasInterAgentRelationshipType
enslaved:hasInterAgentRelationshipType rdf:type owl:ObjectProperty ;
                                       rdfs:domain enslaved:InterAgentRelationshipRecord ;
                                       rdfs:range enslaved:InterAgentRelationshipTypes ;
                                       opla:isNativeTo "https://enslaved.org/ontology/InterAgentRelationshipRecord"^^rdfs:Literal .


###  https://enslaved.org/ontology/hasLicenseInformation
enslaved:hasLicenseInformation rdf:type owl:ObjectProperty ;
                               rdfs:domain enslaved:EntityWithProvenance ;
                               rdfs:range enslaved:LicenseInformation ;
                               opla:isNativeTo "https://enslaved.org/ontology/EntityWithProvenance"^^rdfs:Literal .


###  https://enslaved.org/ontology/hasMatchType
enslaved:hasMatchType rdf:type owl:ObjectProperty ;
                      rdfs:domain enslaved:Match ;
                      rdfs:range enslaved:MatchType .


###  https://enslaved.org/ontology/hasNameRecord
enslaved:hasNameRecord rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf enslaved:hasAgentRecord ;
                       rdfs:domain enslaved:Agent ;
                       rdfs:range enslaved:NameRecord .


###  https://enslaved.org/ontology/hasNameVariant
enslaved:hasNameVariant rdf:type owl:ObjectProperty ;
                        rdfs:domain enslaved:NameRecord ;
                        rdfs:range enslaved:NameVariant ;
                        opla:isNativeTo "https://enslaved.org/ontology/NameRecord"^^rdfs:Literal .


###  https://enslaved.org/ontology/hasOccupationRecord
enslaved:hasOccupationRecord rdf:type owl:ObjectProperty ;
                             rdfs:subPropertyOf enslaved:hasPersonRecord ;
                             rdfs:domain enslaved:Person ;
                             rdfs:range enslaved:OccupationRecord .


###  https://enslaved.org/ontology/hasOriginRecord
enslaved:hasOriginRecord rdf:type owl:ObjectProperty ;
                         rdfs:subPropertyOf enslaved:hasPersonRecord ;
                         rdfs:domain enslaved:Person ;
                         rdfs:range enslaved:OriginRecord .


###  https://enslaved.org/ontology/hasOriginalSourceType
enslaved:hasOriginalSourceType rdf:type owl:ObjectProperty ;
                               rdfs:domain enslaved:EntityWithProvenance ;
                               rdfs:range enslaved:DocumentTypes ;
                               owl:propertyChainAxiom ( enslaved:isDirectlyBasedOn
                                                        enslaved:hasOriginalSourceType
                                                      ) ,
                                                      ( [ owl:inverseOf enslaved:isDirectlyBasedOn
                                                        ]
                                                        [ owl:inverseOf enslaved:hasOriginalSourceType
                                                        ]
                                                      ) ;
                               opla:isNativeTo "https://enslaved.org/ontology/EntityWithProvenance"^^rdfs:Literal .


###  https://enslaved.org/ontology/hasParticipantRoleRecord
enslaved:hasParticipantRoleRecord rdf:type owl:ObjectProperty ;
                                  rdfs:subPropertyOf enslaved:hasAgentRecord ;
                                  owl:inverseOf enslaved:roleProvidedBy ;
                                  rdfs:domain enslaved:Agent ;
                                  rdfs:range enslaved:ParticipantRoleRecord .


###  https://enslaved.org/ontology/hasParticipantRoleType
enslaved:hasParticipantRoleType rdf:type owl:ObjectProperty ;
                                rdfs:domain enslaved:ParticipantRoleRecord ;
                                rdfs:range enslaved:ParticipantRoleTypes ;
                                opla:isNativeTo "https://enslaved.org/ontology/ParticipantRoleRecord"^^rdfs:Literal .


###  https://enslaved.org/ontology/hasPersonRecord
enslaved:hasPersonRecord rdf:type owl:ObjectProperty ;
                         rdfs:subPropertyOf enslaved:hasAgentRecord ;
                         rdfs:domain enslaved:Person ;
                         rdfs:range enslaved:PersonRecord .


###  https://enslaved.org/ontology/hasPersonStatusRecord
enslaved:hasPersonStatusRecord rdf:type owl:ObjectProperty ;
                               rdfs:subPropertyOf enslaved:hasPersonRecord ;
                               rdfs:domain enslaved:Person ;
                               rdfs:range enslaved:PersonStatusRecord .


###  https://enslaved.org/ontology/hasPlaceTypeCV
enslaved:hasPlaceTypeCV rdf:type owl:ObjectProperty ;
                        rdfs:domain [ rdf:type owl:Class ;
                                      owl:unionOf ( enslaved:Place
                                                    enslaved:PlaceCV
                                                  )
                                    ] ;
                        rdfs:range enslaved:PlaceTypeCV .


###  https://enslaved.org/ontology/hasPreferredNameVariant
enslaved:hasPreferredNameVariant rdf:type owl:ObjectProperty ;
                                 rdfs:subPropertyOf enslaved:hasNameVariant ;
                                 rdfs:domain enslaved:NameRecord ;
                                 rdfs:range enslaved:NameVariant ;
                                 opla:isNativeTo "https://enslaved.org/ontology/NameRecord"^^rdfs:Literal .


###  https://enslaved.org/ontology/hasRaceRecord
enslaved:hasRaceRecord rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf enslaved:hasPersonRecord ;
                       rdfs:domain enslaved:Person ;
                       rdfs:range enslaved:RaceRecord .


###  https://enslaved.org/ontology/hasSexRecord
enslaved:hasSexRecord rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf enslaved:hasPersonRecord ;
                      rdfs:domain enslaved:Person ;
                      rdfs:range enslaved:SexRecord .


###  https://enslaved.org/ontology/hasSpatialExtent
enslaved:hasSpatialExtent rdf:type owl:ObjectProperty ;
                          rdfs:domain enslaved:Place ;
                          rdfs:range enslaved:SpatialExtent .


###  https://enslaved.org/ontology/hasStatusGeneratedEvent
enslaved:hasStatusGeneratedEvent rdf:type owl:ObjectProperty ;
                                 rdfs:subPropertyOf enslaved:refersToEvent ;
                                 rdfs:domain enslaved:PersonStatusRecord ;
                                 rdfs:range enslaved:Event ;
                                 opla:isNativeTo "https://enslaved.org/ontology/PersonStatusRecord"^^rdfs:Literal .


###  https://enslaved.org/ontology/hasTemporalExtent
enslaved:hasTemporalExtent rdf:type owl:ObjectProperty ;
                           rdfs:domain [ rdf:type owl:Class ;
                                         owl:unionOf ( enslaved:AgentRecord
                                                       enslaved:Event
                                                       enslaved:Place
                                                     )
                                       ] ;
                           rdfs:range enslaved:TemporalExtent ;
                           opla:isNativeTo "https://enslaved.org/ontology/AgentRecord"^^rdfs:Literal ,
                                           "https://enslaved.org/ontology/Event"^^rdfs:Literal .


###  https://enslaved.org/ontology/hasValue
enslaved:hasValue rdf:type owl:ObjectProperty ;
                  rdfs:domain [ rdf:type owl:Class ;
                                owl:unionOf ( enslaved:AgeRecord
                                              enslaved:OccupationRecord
                                              enslaved:PersonStatusRecord
                                              enslaved:SexRecord
                                            )
                              ] ;
                  rdfs:range [ rdf:type owl:Class ;
                               owl:unionOf ( enslaved:AgeCategory
                                             enslaved:Occupations
                                             enslaved:PSCategories
                                             enslaved:SexTypes
                                           )
                             ] ;
                  opla:isNativeTo "https://enslaved.org/ontology/AgeRecord"^^rdfs:Literal ,
                                  "https://enslaved.org/ontology/OccupationRecord"^^rdfs:Literal ,
                                  "https://enslaved.org/ontology/PersonStatusRecord"^^rdfs:Literal ,
                                  "https://enslaved.org/ontology/SexRecord"^^rdfs:Literal .


###  https://enslaved.org/ontology/isAdministrativePartOf
enslaved:isAdministrativePartOf rdf:type owl:ObjectProperty ;
                                rdfs:domain [ rdf:type owl:Class ;
                                              owl:unionOf ( enslaved:Place
                                                            enslaved:PlaceCV
                                                          )
                                            ] ;
                                rdfs:range enslaved:PlaceCV .


###  https://enslaved.org/ontology/isDirectlyBasedOn
enslaved:isDirectlyBasedOn rdf:type owl:ObjectProperty ;
                           rdfs:domain enslaved:EntityWithProvenance ;
                           rdfs:range enslaved:EntityWithProvenance ;
                           opla:isNativeTo "https://enslaved.org/ontology/EntityWithProvenance"^^rdfs:Literal .


###  https://enslaved.org/ontology/isRelationshipFrom
enslaved:isRelationshipFrom rdf:type owl:ObjectProperty ;
                            rdfs:domain enslaved:InterAgentRelationshipRecord ;
                            rdfs:range enslaved:Agent ;
                            opla:isNativeTo "https://enslaved.org/ontology/InterAgentRelationshipRecord"^^rdfs:Literal .


###  https://enslaved.org/ontology/isRelationshipTo
enslaved:isRelationshipTo rdf:type owl:ObjectProperty ;
                          rdfs:domain enslaved:InterAgentRelationshipRecord ;
                          rdfs:range enslaved:Agent ;
                          opla:isNativeTo "https://enslaved.org/ontology/InterAgentRelationshipRecord"^^rdfs:Literal .


###  https://enslaved.org/ontology/isSpatiallyLocatedIn
enslaved:isSpatiallyLocatedIn rdf:type owl:ObjectProperty ;
                              rdfs:domain [ rdf:type owl:Class ;
                                            owl:unionOf ( enslaved:Place
                                                          enslaved:PlaceCV
                                                        )
                                          ] ;
                              rdfs:range [ rdf:type owl:Class ;
                                           owl:unionOf ( enslaved:Place
                                                         enslaved:PlaceCV
                                                       )
                                         ] ;
                              opla:isNativeTo "https://enslaved.org/ontology/Place"^^rdfs:Literal .


###  https://enslaved.org/ontology/matches
enslaved:matches rdf:type owl:ObjectProperty ;
                 rdfs:domain enslaved:Match ;
                 rdfs:range owl:Thing .


###  https://enslaved.org/ontology/performedBy
enslaved:performedBy rdf:type owl:ObjectProperty ;
                     rdfs:domain enslaved:ProvenanceActivity ;
                     rdfs:range enslaved:Agent ;
                     opla:isNativeTo "https://enslaved.org/ontology/EntityWithProvenance"^^rdfs:Literal .


###  https://enslaved.org/ontology/providesParticipantRole
enslaved:providesParticipantRole rdf:type owl:ObjectProperty ;
                                 rdfs:domain enslaved:Event ;
                                 rdfs:range enslaved:ParticipantRoleRecord ;
                                 opla:isNativeTo "https://enslaved.org/ontology/Event"^^rdfs:Literal ,
                                                 "https://enslaved.org/ontology/ResearchProject"^^rdfs:Literal .


###  https://enslaved.org/ontology/recordedAt
enslaved:recordedAt rdf:type owl:ObjectProperty ;
                    rdfs:domain enslaved:AgentRecord ;
                    rdfs:range enslaved:Event ;
                    opla:isNativeTo "https://enslaved.org/ontology/AgentRecord"^^rdfs:Literal .


###  https://enslaved.org/ontology/refersTo
enslaved:refersTo rdf:type owl:ObjectProperty ;
                  rdfs:domain enslaved:ExternalReference ;
                  rdfs:range enslaved:ExternalReferent ;
                  opla:isNativeTo "https://enslaved.org/ontology/ExternalReference"^^rdfs:Literal .


###  https://enslaved.org/ontology/refersToEvent
enslaved:refersToEvent rdf:type owl:ObjectProperty ;
                       rdfs:domain enslaved:PersonStatusRecord ;
                       rdfs:range enslaved:Event ;
                       opla:isNativeTo "https://enslaved.org/ontology/PersonStatusRecord"^^rdfs:Literal .


###  https://enslaved.org/ontology/refersToPlaceOfOrigin
enslaved:refersToPlaceOfOrigin rdf:type owl:ObjectProperty ;
                               rdfs:domain enslaved:OriginRecord ;
                               rdfs:range enslaved:Place ;
                               opla:isNativeTo "https://enslaved.org/ontology/OriginRecord"^^rdfs:Literal .


###  https://enslaved.org/ontology/reportsOn
enslaved:reportsOn rdf:type owl:ObjectProperty ;
                   rdfs:domain enslaved:EntityWithProvenance ;
                   rdfs:range enslaved:Event ;
                   owl:propertyChainAxiom ( enslaved:agentRecordSelfProperty
                                            enslaved:recordedAt
                                            enslaved:eventSelfProperty
                                          ) ;
                   opla:isNativeTo "https://enslaved.org/ontology/EntityWithProvenance"^^rdfs:Literal .


###  https://enslaved.org/ontology/roleProvidedBy
enslaved:roleProvidedBy rdf:type owl:ObjectProperty ;
                        rdfs:domain enslaved:ParticipantRoleRecord ;
                        rdfs:range enslaved:Agent ;
                        opla:isNativeTo "https://enslaved.org/ontology/ParticipantRoleRecord"^^rdfs:Literal .


###  https://enslaved.org/ontology/subeventOf
enslaved:subeventOf rdf:type owl:ObjectProperty ;
                    rdfs:domain enslaved:Event ;
                    rdfs:range enslaved:Event ;
                    opla:isNativeTo "https://enslaved.org/ontology/Event"^^rdfs:Literal .


###  https://enslaved.org/ontology/used
enslaved:used rdf:type owl:ObjectProperty ;
              rdfs:domain enslaved:ProvenanceActivity ;
              rdfs:range enslaved:EntityWithProvenance ;
              opla:isNativeTo "https://enslaved.org/ontology/EntityWithProvenance"^^rdfs:Literal .


#################################################################
#    Data properties
#################################################################

###  https://enslaved.org/ontology/asText
enslaved:asText rdf:type owl:DatatypeProperty ;
                rdfs:domain [ rdf:type owl:Class ;
                              owl:unionOf ( enslaved:Description
                                            enslaved:RaceRecord
                                          )
                            ] ;
                rdfs:range xsd:string ;
                opla:isNativeTo "https://enslaved.org/ontology/Description"^^rdfs:Literal ,
                                "https://enslaved.org/ontology/RaceRecord"^^rdfs:Literal .


###  https://enslaved.org/ontology/availableFrom
enslaved:availableFrom rdf:type owl:DatatypeProperty ;
                       rdfs:domain enslaved:EntityWithProvenance ;
                       rdfs:range xsd:string ;
                       opla:isNativeTo "https://enslaved.org/ontology/EntityWithProvenance"^^rdfs:Literal .


###  https://enslaved.org/ontology/contains
enslaved:contains rdf:type owl:DatatypeProperty ;
                  rdfs:domain enslaved:TemporalExtent ;
                  rdfs:range xsd:date ;
                  opla:isNativeTo "https://enslaved.org/ontology/TemporalExtent"^^rdfs:Literal .


###  https://enslaved.org/ontology/endsAt
enslaved:endsAt rdf:type owl:DatatypeProperty ;
                rdfs:domain enslaved:TemporalExtent ;
                rdfs:range xsd:date ;
                opla:isNativeTo "https://enslaved.org/ontology/TemporalExtent"^^rdfs:Literal .


###  https://enslaved.org/ontology/fullNameAsString
enslaved:fullNameAsString rdf:type owl:DatatypeProperty ;
                          rdfs:domain enslaved:NameRecord ;
                          rdfs:range xsd:string ;
                          opla:isNativeTo "https://enslaved.org/ontology/NameRecord"^^rdfs:Literal .


###  https://enslaved.org/ontology/hasAgeValue
enslaved:hasAgeValue rdf:type owl:DatatypeProperty ;
                     rdfs:domain enslaved:AgeRecord ;
                     rdfs:range xsd:double ;
                     opla:isNativeTo "https://enslaved.org/ontology/AgeRecord"^^rdfs:Literal .


###  https://enslaved.org/ontology/hasAlternateName
enslaved:hasAlternateName rdf:type owl:DatatypeProperty ;
                          rdfs:domain [ rdf:type owl:Class ;
                                        owl:unionOf ( enslaved:Place
                                                      enslaved:PlaceCV
                                                    )
                                      ] ;
                          rdfs:range xsd:string ;
                          opla:isNativeTo "https://enslaved.org/ontology/Place"^^rdfs:Literal .


###  https://enslaved.org/ontology/hasDescriptiveEthnonym
enslaved:hasDescriptiveEthnonym rdf:type owl:DatatypeProperty ;
                                rdfs:domain enslaved:OriginRecord ;
                                rdfs:range xsd:string .


###  https://enslaved.org/ontology/hasDescriptiveOccupation
enslaved:hasDescriptiveOccupation rdf:type owl:DatatypeProperty ;
                                  rdfs:domain enslaved:OccupationRecord ;
                                  rdfs:range xsd:string .


###  https://enslaved.org/ontology/hasFirstNameAsString
enslaved:hasFirstNameAsString rdf:type owl:DatatypeProperty ;
                              rdfs:domain enslaved:NameRecord ;
                              rdfs:range xsd:string ;
                              opla:isNativeTo "https://enslaved.org/ontology/NameRecord"^^rdfs:Literal .


###  https://enslaved.org/ontology/hasLatitude
enslaved:hasLatitude rdf:type owl:DatatypeProperty ;
                     rdfs:domain enslaved:Coordinates ;
                     rdfs:range xsd:double ;
                     opla:isNativeTo "https://enslaved.org/ontology/Place"^^rdfs:Literal .


###  https://enslaved.org/ontology/hasLongitude
enslaved:hasLongitude rdf:type owl:DatatypeProperty ;
                      rdfs:domain enslaved:Coordinates ;
                      rdfs:range xsd:double ;
                      opla:isNativeTo "https://enslaved.org/ontology/Place"^^rdfs:Literal .


###  https://enslaved.org/ontology/hasName
enslaved:hasName rdf:type owl:DatatypeProperty ;
                 rdfs:domain [ rdf:type owl:Class ;
                               owl:unionOf ( enslaved:Event
                                             enslaved:Place
                                           )
                             ] ;
                 rdfs:range xsd:string ;
                 opla:isNativeTo "https://enslaved.org/ontology/Event"^^rdfs:Literal ,
                                 "https://enslaved.org/ontology/Place"^^rdfs:Literal ,
                                 "https://enslaved.org/ontology/ResearchProject"^^rdfs:Literal .


###  https://enslaved.org/ontology/hasReferenceURI
enslaved:hasReferenceURI rdf:type owl:DatatypeProperty ;
                         rdfs:domain enslaved:EntityWithProvenance ;
                         rdfs:range xsd:anyURI ;
                         opla:isNativeTo "https://enslaved.org/ontology/EntityWithProvenance"^^rdfs:Literal .


###  https://enslaved.org/ontology/hasSurnameAsString
enslaved:hasSurnameAsString rdf:type owl:DatatypeProperty ;
                            rdfs:domain enslaved:NameRecord ;
                            rdfs:range xsd:string ;
                            opla:isNativeTo "https://enslaved.org/ontology/NameRecord"^^rdfs:Literal .


###  https://enslaved.org/ontology/occursAfter
