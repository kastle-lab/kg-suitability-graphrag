                            owl:onProperty enslaved:refersToEvent ;
                            owl:allValuesFrom enslaved:Event
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty enslaved:subeventOf ;
                            owl:allValuesFrom enslaved:Event
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty [ owl:inverseOf enslaved:hasDescriptionText
                                           ] ;
                            owl:maxCardinality "1"^^xsd:nonNegativeInteger
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty [ owl:inverseOf enslaved:hasExternalReference
                                           ] ;
                            owl:maxCardinality "1"^^xsd:nonNegativeInteger
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty enslaved:fullNameAsString ;
                            owl:allValuesFrom xsd:string
                          ] ,
                          [ rdf:type owl:Restriction ;
