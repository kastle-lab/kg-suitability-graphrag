                            owl:allValuesFrom enslaved:SpatialExtent
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty enslaved:hasTemporalExtent ;
                            owl:allValuesFrom enslaved:TemporalExtent
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty enslaved:providesParticipantRole ;
                            owl:allValuesFrom enslaved:ParticipantRoleRecord
